int main() {
    ifstream plik("mecz_przyklad.txt");
    ofstream wyniki("wyniki1.txt");
    char tab[10001];
    plik >> tab;
    plik.close();
    
    int licznik = 0;
    
    //4.1
    
    for(int i = 1; tab[i] != '\0' ; i++) {
        if(tab[i] != tab[i-1]) {
            licznik++;
        }
        
    }
    wyniki << licznik << endl;
    
    //4.2 
    
    int punktyA = 0;
    int punktyB = 0;
    int wygraneA = 0;
    int wygraneB = 0;
    
    for(int i = 0; tab[i] != '\0'; i++) {
        if(tab[i] == 'A') {
            punktyA++;
        } else if (tab[i] == 'B'){
            punktyB++;
        }
        if(punktyA >= 1000 && punktyA - punktyB >= 3) {
            wygraneA++;
