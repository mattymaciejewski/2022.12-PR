        } else if (punktyB >= 1000 && punktyB - punktyA >= 3) {
            wygraneB++;
            wyniki << "B " << punktyB << ":" << punktyA << endl;
            break;
        }
    }
    
    //4.3 
    
    int passa = 1;
    int licznikPass = 0;
    int najdluzszaPassa = 0;
    char aktualnaDruzyna = tab[0];
    char najdluzszaDruzyna;
    for(int i = 1; tab[i] != '\0'; i++) {
        if(tab[i] == aktualnaDruzyna) {
            passa++;
        } else {
            if(passa >= 10) {
                licznikPass++;
            } 
            if(passa >= najdluzszaPassa) {
            najdluzszaPassa = passa;
            najdluzszaDruzyna = aktualnaDruzyna;
            }
            aktualnaDruzyna = tab[i];
            passa = 1;
        } 
    }
    if(passa >= 10) {
        licznikPass++;
